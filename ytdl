#!/bin/bash

set -euo pipefail

COOKIES="${COOKIES:-cookies.txt}"

cookies_args=()
[[ -f "$COOKIES" ]] && cookies_args=(--cookies "$COOKIES")

if [[ $# -gt 0 ]]; then
    yt-dlp "${cookies_args[@]}" \
        --retries 50 \
        --retry-sleep exp=1:300 \
        --fragment-retries 50 \
        "$@" || exit 1
fi

for f in *.webm; do
    [[ -e "$f" ]] || break
    ytpp "$f"
done
