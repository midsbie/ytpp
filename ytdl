#!/bin/bash

set -euo pipefail

COOKIES="${COOKIES:-cookies.txt}"

cookies_args=()
[[ -f "$COOKIES" ]] && cookies_args=(--cookies "$COOKIES")

js_args=()
command -v node &>/dev/null && js_args=(--js-runtimes node)

if [[ $# -gt 0 ]]; then
    yt-dlp "${cookies_args[@]}" "${js_args[@]}" \
        -f "bv*+ba/b" \
        --extractor-args "youtube:player_client=tv,mweb;lang=en" \
        --retries 50 \
        --retry-sleep exp=1:15 \
        --fragment-retries 50 \
        "$@" || exit 1
fi
