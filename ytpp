#!/bin/bash

set -euo pipefail

readonly VAAPI_DEVICE="${VAAPI_DEVICE:-/dev/dri/renderD128}"
readonly VAAPI_VF_BASE="format=p010,hwupload"
readonly VAAPI_ENCODER_ARGS=(-c:v hevc_vaapi -profile:v main10)
readonly DEFAULT_QUALITY=17

usage() {
    cat <<EOF
Usage: ${0##*/} [options] [file]

Convert videos with AV1/Opus codecs to H.265/AC3 for TV compatibility.
With no file argument, processes all .webm files in the current directory.

Options:
  -q, --quality <n>  Quality level: QP for VAAPI/NVENC, CRF for software (default: ${DEFAULT_QUALITY}, lower=better)
  -f, --force        Force transcoding even if codecs are already compatible
  --sw               Force software encoding (libx265)
  --no-delete        Keep original file after conversion
  -h, --help         Show this help message
EOF
}

die() {
    echo "Error: $1" >&2
    exit 1
}

# Test whether NVENC HEVC encoding is available
nvenc_available() {
    ffmpeg -hide_banner -f lavfi -i nullsrc -t 0.1 -c:v hevc_nvenc -f null - 2>/dev/null
}

# Test whether the VAAPI device supports HEVC encoding with our settings
vaapi_available() {
    [[ -r "$VAAPI_DEVICE" ]] &&
        ffmpeg -hide_banner -vaapi_device "$VAAPI_DEVICE" \
            -f lavfi -i nullsrc -t 0.1 \
            -vf "$VAAPI_VF_BASE" "${VAAPI_ENCODER_ARGS[@]}" \
            -f null - 2>/dev/null
}

# Returns 0 (needs processing) or 1 (skip). Prints status messages.
# On success, converts the file and optionally deletes the original.
process_file() {
    local input_file="$1"

    [[ -f "$input_file" ]] || { echo "Error: File '$input_file' not found" >&2; return 1; }

    local extension="${input_file##*.}"

    # Only process video containers we care about
    if [[ ! "$extension" =~ ^(webm|mkv|mp4)$ ]]; then
        echo "Skipping '$input_file': not webm/mkv/mp4"
        return 0
    fi

    # Get video and audio codecs and dimensions (two probes: one per stream type)
    local video_codec video_width video_height audio_codec
    IFS=',' read -r video_codec video_width video_height < <(
        ffprobe -v error -select_streams v:0 \
            -show_entries stream=codec_name,width,height \
            -of csv=p=0 "$input_file"
    )
    audio_codec=$(ffprobe -v error -select_streams a:0 \
        -show_entries stream=codec_name \
        -of default=noprint_wrappers=1:nokey=1 "$input_file")

    echo "Detected video codec: $video_codec"
    echo "Detected audio codec: $audio_codec"

    # Determine if we need to re-encode
    local needs_video_reencode=false
    local needs_audio_reencode=false

    if [[ "$force_transcode" == true ]]; then
        needs_video_reencode=true
        needs_audio_reencode=true
    else
        # AV1 not supported by older TVs (e.g., LG C8)
        if [[ "$video_codec" == "av1" ]]; then
            needs_video_reencode=true
        fi

        # Opus not widely supported on TVs
        if [[ "$audio_codec" == "opus" ]]; then
            needs_audio_reencode=true
        fi

        if [[ "$needs_video_reencode" == false && "$needs_audio_reencode" == false ]]; then
            echo "No conversion needed for '$input_file'"
            return 0
        fi
    fi

    # Build output filename
    local output_file="${input_file%.*}.mkv"
    if [[ "$output_file" == "$input_file" ]]; then
        output_file="${input_file%.*}_converted.mkv"
    fi

    # Build ffmpeg command
    local ffmpeg_args=()

    # NVENC: use CUVID hardware decoding
    # ===================================
    # Without -hwaccel cuda, ffmpeg decodes the input (e.g., VP9 webm) in software, which can
    # saturate 8-10 CPU cores even though encoding is on the GPU. Adding -hwaccel cuda offloads
    # decoding to the GPU's dedicated NVDEC block. Frames are copied back to system memory for the
    # encoder, so pix_fmt and other options work unchanged.
    if [[ "$encoder" == "nvenc" ]]; then
        ffmpeg_args+=(-hwaccel cuda)
    elif [[ "$encoder" == "vaapi" ]]; then
        ffmpeg_args+=(-vaapi_device "$VAAPI_DEVICE")
    fi

    ffmpeg_args+=(-i "$input_file")

    if [[ "$needs_video_reencode" == true ]]; then
        case "$encoder" in
            nvenc)
                # NVENC HEVC encoding args
                # ========================
                # -preset p7 -tune hq   Slowest preset + quality tuning (max encoder effort)
                # -rc vbr -cq $quality  Variable bitrate with constant quality target: adapts
                #                       bitrate per frame based on content complexity, unlike
                #                       constqp which applies a fixed QP to every frame
                # -rc-lookahead 64      Frames to buffer before encoding; lets the rate controller
                #                       see upcoming scene changes and allocate bits accordingly
                #                       (higher = better decisions, more memory)
                # -bf 4                 Max consecutive B-frames; B-frames reference both past and
                #                       future frames so they compress more efficiently
                # -b_ref_mode middle    Allows B-frames to be used as references by other B-frames,
                #                       further improving compression
                # -spatial-aq 1         Redistributes bits within each frame toward flat/smooth
                #                       areas where blocking artifacts are most visible
                # -temporal-aq 1        Redistributes bits across frames based on temporal
                #                       complexity (e.g., less bits to static scenes)
                # -multipass fullres    Two-pass encoding: first pass analyzes the full resolution
                #                       video, second pass uses that data for better bit allocation
                #                       decisions
                # -pix_fmt p010le       10-bit color depth; reduces banding in gradients
                echo "Will re-encode video from $video_codec to H.265 via NVENC hardware..."
                ffmpeg_args+=(-c:v hevc_nvenc -preset p7 -tune hq \
                    -rc vbr -cq "$quality" \
                    -rc-lookahead 64 \
                    -bf 4 -b_ref_mode middle -spatial-aq 1 -temporal-aq 1 \
                    -multipass fullres \
                    -pix_fmt p010le)
                ;;
            vaapi)
                # VAAPI HEVC encoding caveats (Mesa radeonsi)
                # ===========================================
                # The Mesa radeonsi VA-API driver (the default open-source AMD driver on Linux) has
                # known issues with HEVC encoding. These are driver-level bugs, not ffmpeg issues:
                #
                # 1. Green bar artifact: AMD VAAPI HEVC encoders require heights divisible by 32.
                #    Non-aligned heights (e.g., 1080) cause the encoder to pad to the next aligned
                #    value (1088), filling extra rows with uninitialized data that appears as a
                #    green bar at the bottom of the video.
                #
                # 2. Intermittent frame corruption: the Mesa VAAPI HEVC encoder can produce
                #    malformed frames at unpredictable points, causing playback issues that vary by
                #    decoder. On TVs this manifests as audio stuttering and resync pauses (the
                #    hardware decoder stalls on a bad frame, starving the audio buffer); in VLC it
                #    shows as visual corruption. This was initially misattributed to Opus->AAC
                #    audio transcoding issues but was observed even with AC3 audio when using
                #    VAAPI-encoded video.
                #
                # NVENC (when available) appeared to avoid both issues entirely in limited testing
                # so far. VAAPI remains as a fallback for systems without NVIDIA GPUs.
                #
                # Green bar fix
                #
                # Failed approaches:
                # 1. scale_vaapi=force_divisible_by=16 - Operates AFTER hwupload, but the green bar
                #    originates during encoding, not upload. Also, 1080 is already divisible by 16;
                #    the encoder needs 32-byte alignment.
                # 2. scale=iw:ih before hwupload - Forces frame reallocation but doesn't address the
                #    encoder's internal padding behavior.
                # 3. pad + scale_vaapi crop - Padding adds black pixels; scaling back down
                #    compresses them into the frame rather than cropping, causing a black bar.
                # 4. crop to 1056 (32-aligned) - Works but loses 24 pixels of actual content.
                #
                # Working approach: Scale UP to 32-aligned height in software, upload to VAAPI, then
                # scale back DOWN to original height with scale_vaapi. The double-scale cancels out
                # with minimal quality loss (<1% dimension change for 1080p).
                #
                # Caveats:
                # - Two scaling operations introduce minor quality loss (imperceptible for most
                #   content, but may affect fine details or text at frame edges)
                # - Slightly slower than direct encoding due to extra scale operations
                # - If height is already 32-aligned (720p, 2160p), scaling is a no-op
                #
                # References:
                # - https://www.mail-archive.com/debian-bugs-dist@lists.debian.org/msg1990958.html
                # - https://obsproject.com/forum/threads/experimental-ffmpeg-vaapi-plugin.61529/page-2
                echo "Will re-encode video from $video_codec to H.265 via VAAPI hardware..."
                local aligned_height=$(( ((video_height + 31) / 32) * 32 ))

                # Build VAAPI filter chain: always need format=p010,hwupload; conditionally wrap
                # with double-scale for 32-byte alignment (see detailed explanation above). No
                # -aspect flag needed: scale_vaapi restores original dimensions so ffmpeg derives
                # DAR correctly, and omitting it preserves anamorphic SAR.
                local vf="$VAAPI_VF_BASE"
                if [[ "$aligned_height" -ne "$video_height" ]]; then
                    vf="scale=${video_width}:${aligned_height},${vf},scale_vaapi=w=${video_width}:h=${video_height}"
                fi
                ffmpeg_args+=(-vf "$vf" "${VAAPI_ENCODER_ARGS[@]}" -qp "$quality")
                ;;
            sw)
                echo "Will re-encode video from $video_codec to H.265 via software..."
                ffmpeg_args+=(-c:v libx265 -crf "$quality" -preset medium -pix_fmt yuv420p10le -x265-params aq-mode=3)
                ;;
        esac
    else
        ffmpeg_args+=(-c:v copy)
    fi

    if [[ "$needs_audio_reencode" == true ]]; then
        # Opus to AC3 (Dolby Digital) instead of AAC
        # ==========================================
        # NOTE: The audio stuttering originally attributed to Opus->AAC transcoding was likely
        # caused by VAAPI HEVC video encoding bugs in Mesa radeonsi (see VAAPI comment above).
        # Malformed video frames cause TV hardware decoders to stall, starving the audio buffer and
        # producing symptoms that mimic audio codec issues. The AC3 switch may be unnecessary on
        # systems using NVENC or other reliable encoders, but AC3 remains a safe choice given its
        # universal TV support as the DVD/Blu-ray standard.
        #
        # Original theory (may still be a contributing factor for AAC specifically):
        # - Frame size mismatch: Opus uses 960 samples/frame, AAC expects 1024, causing micro-gaps
        # - PTS discontinuities in YouTube downloads mishandled by ffmpeg's native AAC encoder
        # References:
        #   - https://libav-user.ffmpeg.narkive.com/LlO8JSzP/opus-transcoding-to-aac-but-960-sample-increase-to-1024-with-a-nomalized-blank-data
        #   - https://trac.ffmpeg.org/ticket/4676
        echo "Will re-encode audio from $audio_codec to AC3 (Dolby Digital)..."
        ffmpeg_args+=(-c:a ac3 -b:a 384k)
    else
        ffmpeg_args+=(-c:a copy)
    fi

    ffmpeg_args+=("$output_file")

    echo "Converting..."
    ffmpeg -hide_banner "${ffmpeg_args[@]}" || { echo "Error: Conversion failed for '$input_file'" >&2; return 1; }
    echo "Created: $output_file"

    if [[ "$delete_original" == true && "$input_file" != "$output_file" ]]; then
        rm "$input_file"
        echo "Deleted: $input_file"
    fi
}

# Defaults
quality="$DEFAULT_QUALITY"
force_sw=false
force_transcode=false
delete_original=true

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -q|--quality)
            [[ $# -ge 2 ]] || die "-q/--quality requires a value"
            quality="$2"
            [[ "$quality" =~ ^[0-9]+$ ]] || die "Quality must be a positive integer"
            shift 2
            ;;
        -q=*|--quality=*)
            quality="${1#*=}"
            [[ "$quality" =~ ^[0-9]+$ ]] || die "Quality must be a positive integer"
            shift
            ;;
        -f|--force)
            force_transcode=true
            shift
            ;;
        --sw)
            force_sw=true
            shift
            ;;
        --no-delete)
            delete_original=false
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        -*)
            die "Unknown option: $1"
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -gt 0 ]]; then
    files=("$@")
else
    files=(*.webm)
    [[ -e "${files[0]}" ]] || { echo "No .webm files found"; exit 2; }
fi

# Select video encoder: NVENC > VAAPI > software
if [[ "$force_sw" == true ]]; then
    encoder=sw
elif nvenc_available; then
    encoder=nvenc
elif vaapi_available; then
    encoder=vaapi
else
    encoder=sw
fi

failures=0
for input_file in "${files[@]}"; do
    process_file "$input_file" || ((failures++))
done
((failures)) && exit 1
